{
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.8.0"
        }
    },
    "routes": [
        {
            "src": "/articles",
            "dest": "/resources/views/articles.blade.php"
        },

        {
            "src": "/(.*)",
            "dest": "/resources/views/home.blade.php"
        }
    ]
}
